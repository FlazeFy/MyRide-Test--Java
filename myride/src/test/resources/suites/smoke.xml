<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite" parallel="tests" thread-count="2">
    <test name="Login Page Basic Auth Tests">
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>
    <test name="API Integration Test : Stats Module">
        <classes>
            <class name="api.stats.GetSummary"/>
            <class name="api.stats.GetTotalTripByContext"/>
            <class name="api.stats.GetTripPartner"/>
            <class name="api.stats.GetTotalVehicleByContext"/>
            <class name="api.stats.GetTotalTripMonthlyByYearAndVehicleId"/>
        </classes>
    </test>
    <test name="API Integration Test : History Module">
        <classes>
            <class name="api.history.GetAllHistory"/>
        </classes>
    </test>
    <test name="API Integration Test : Driver Module">
        <classes>
            <class name="api.driver.GetAllDriverName"/>
            <class name="api.driver.GetAllDriver"/>
            <class name="api.driver.GetAllDriverVehicle"/>
            <class name="api.driver.GetAllDriverVehicleManagementList"/>
        </classes>
    </test>
    <test name="API Integration Test : Question Module">
        <classes>
            <class name="api.question.GetShowingFAQ"/>
        </classes>
    </test>
    <test name="API Integration Test : Dictionary Module">
        <classes>
            <class name="api.dictionary.GetAllDictionaryByType"/>
        </classes>
    </test>
    <test name="API Integration Test : Fuel Module">
        <classes>
            <class name="api.fuel.GetAllFuel"/>
            <class name="api.fuel.GetLastFuel"/>
            <class name="api.fuel.GetFuelSummary"/>
        </classes>
    </test>
    <test name="API Integration Test : Reminder Module">
        <classes>
            <class name="api.reminder.GetAllReminder"/>
            <class name="api.reminder.GetNextReminder"/>
            <class name="api.reminder.GetRecentlyReminder"/>
            <class name="api.reminder.GetReminderByVehicleId"/>
        </classes>
    </test>
    <test name="API Integration Test : Service Module">
        <classes>
            <class name="api.service.GetAllService"/>
            <class name="api.service.GetServiceSpending"/>
            <class name="api.service.GetNextService"/>
            <class name="api.service.GetServiceByVehicleId"/>
        </classes>
    </test>
</suite>